# Google Gemini API key (obtained from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Database URL
# Leave blank to fall back to SQLite automatically (/tmp/flowzint.db or local flowzint.db)
# For production persistence on Vercel/Render, supply a PostgreSQL connection string:
# DATABASE_URL=postgresql://username:password@host:5432/database
DATABASE_URL=

# Listening Port
PORT=8000
